{
  "sumati-001": {
    "title": "ఉపచారకి సుపచారము",
    "lines": [
      "ఉపచారకి సుపచారము",
      "విపరీతము గాదు సేవా విపరంపంగా",
      "సపచారకి సుపచారము",
      "నెపమెన్నక సేవయవాడు నెప్తి సుమతి."
    ],
    "meaning": [
      "సేవ చేయడంలో నిజమైన మనసు ఉండాలి.",
      "విపరీతంగా లేదా అహంకారంతో చేసిన సేవ విలువైనది కాదు."
    ],
    "moral": "సేవలో వినయం, నిజాయితీ ఉండాలి.",
    "audio": "sumati_001.mp3"
  },

  "sumati-002": {
    "title": "ఎప్పటి తెల్లవారిప్రస్థాన",
    "lines": [
      "ఎప్పటి తెల్లవారిప్రస్థాన",
      "మధ్యటి కాంతలాడి యన్నుల మనముల్",
      "నొప్పినిక శానోపక",
      "తెప్పించుక తిరుగువాడ ధన్యుడు సుమతీ."
    ],
    "meaning": [
      "ఎప్పుడూ కష్టపడే మనిషి ధన్యుడు.",
      "కష్టాలను తట్టుకుని ముందుకు సాగేవాడు విజయాన్ని పొందుతాడు."
    ],
    "moral": "కష్టపడే మనిషి ఎప్పుడూ విజయవంతుడవుతాడు.",
    "audio": "sumati_002.mp3"
  },

  "sumati-003": {
    "title": "కనకప్ర సింహాసనమున",
    "lines": [
      "కనకప్ర సింహాసనమున",
      "శునకమునుగు గుహాండడెట్టి శుభలక్ష్ముమునన్",
      "వాసరగడ్లమున గల్గిన",
      "వెనుకటిగు గణమెల మాను వినరా సుమతి."
    ],
    "meaning": [
      "ధనవంతుడు అయినా, వినయం లేకపోతే విలువ ఉండదు.",
      "అహంకారంతో ఉన్నవాడు గౌరవం కోల్పోతాడు."
    ],
    "moral": "వినయం మనిషిని ఉన్నతుడిని చేస్తుంది.",
    "audio": "sumati_003.mp3"
  },

  "sumati-004": {
    "title": "కూలిమిగల దినములో",
    "lines": [
      "కూలిమిగల దినములో",
      "నేరములెన్నడును గలుగ నేర్పు మతి యా",
      "కూలిమి విరసంబైనను",
      "నేరములే చూపుచుండు నిక్కము సుమతి."
    ],
    "meaning": [
      "కూలి తక్కువైనా, పనిలో నిజాయితీ ఉండాలి.",
      "నేరం చేయకుండా కష్టపడి జీవించాలి."
    ],
    "moral": "నిజాయితీతో పని చేయడం గొప్ప గుణం.",
    "audio": "sumati_004.mp3"
  },

  "sumati-005": {
    "title": "తలనుండు విషము ఫణికిన్",
    "lines": [
      "తలనుండు విషము ఫణికిన్",
      "తెలియంగాదోకనుండు వ్యథికమునకున్",
      "దలదోష యునకనుండు",
      "ఫలముకు నిలువెల్లి విషముగదరా సుమతి."
    ],
    "meaning": [
      "విషం తలలో ఉన్న పామును చూసి భయపడతాం.",
      "అలాగే చెడు మనసు ఉన్నవాడు సమాజానికి ప్రమాదం."
    ],
    "moral": "చెడు మనసు ఉన్నవారిని దూరంగా ఉంచాలి.",
    "audio": "sumati_005.mp3"
  }
}
