{
  "vemana-001": {
    "title": "ఉప్పు కప్పురంబు ఒక్క పోలికనుండు ",
    "lines": [
      "ఉప్పు కప్పురంబు ఒక్క పోలికనుండు",
      "చూడచూడ రుచుల జాడవేరు",
      "పురుషులందు పుణ్యపురుషులు వేరయా",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "ఉప్పు, కర్పూరం రెండూ తెల్లగా ఉంటాయి కానీ రుచి వేరు.",
      "అలాగే మనుషులందరూ ఒకేలా కనిపించినా, వారి గుణాలు వేరు."
    ],
    "moral": "బాహ్య రూపం కాదు, గుణమే మనిషిని గొప్పవాడిని చేస్తుంది.",
    "audio": "vemana_001.mp3"
  },

  "vemana-002": {
    "title": "విత్తముగలవాని వీపున బుండైన",
    "lines": [
      "విత్తముగలవాని వీపున బుండైన",
      "వనధలోనజాల వార్త కెక్కు",
      "బేదవానియింట బెండ్లైన నెఱుగరు",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "ధనవంతునికి చిన్న పుండయినా ప్రపంచం అంతా తెలుస్తుంది.",
      "పేదవాని ఇంట్లో పెళ్లి జరిగినా ఎవరికీ తెలియదు."
    ],
    "moral": "సంపద ఉన్నవారికి మాత్రమే కాదు, అందరికీ సమానంగా గౌరవం ఇవ్వాలి.",
    "audio": "vemana_002.mp3"
  },

  "vemana-003": {
    "title": "అనువుగానిచోట నధికుల మనరాదు",
    "lines": [
      "అనువుగానిచోట నధికుల మనరాదు",
      "కొంచమైన నదియు గొదువగాదు",
      "కొండ యద్ధమందు గొంచమైయుండదా!",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "పెద్దకొండ కూడ అద్దమందు ప్రతిబింబములో చిన్నదిగా కనిపించినా",
      "దాని గొప్పదనము తగ్గనట్లే మనుజుడు కానిచోట్ల అహంకరింప కూడదు."
    ],
    "moral": "ప్రతి వ్యక్తి తన స్థాయిని గుర్తించి జీవించాలి.",
    "audio": "vemana_003.mp3"
  },

  "vemana-004": {
    "title": "అనగ ననగ రాగ మతిశయిల్లుచునుండు",
    "lines": [
      "అనగ ననగ రాగ మతిశయిల్లుచునుండు",
      "దినదినగ వేము తియ్యగనుండు",
      "సాధనమునపనులు సమకూరు ధరలోన",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "అభ్యాసంతో ప్రతిభ పెరుగుతుంది.",
      "రోజురోజుకూ సాధన ఫలితాన్ని ఇస్తుంది."
    ],
    "moral": "అభ్యాసం మనిషిని ఉన్నతుడిని చేస్తుంది.",
    "audio": "vemana_004.mp3"
  },

  "vemana-005": {
    "title": "తప్పులెన్నివారు తండోప తండంబు",
    "lines": [
      "తప్పులెన్నివారు తండోప తండంబు",
      "ఉరిగజనులెక్కల నుండి దశ్వ",
      "తప్పులెన్నివారు తమతప్పులెరుగరు",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "మనుషులు తమ తప్పులను గుర్తించరు.",
      "ఇతరుల తప్పులను మాత్రం పెద్దగా చూపిస్తారు."
    ],
    "moral": "తప్పులను గుర్తించి సరిదిద్దుకోవడం మంచిది.",
    "audio": "vemana_005.mp3"
  },

  "vemana-006": {
    "title": "ఎలుకతొలు డెచ్చు యెదాది పుతికిన",
    "lines": [
      "ఎలుకతొలు డెచ్చు యెదాది పుతికిన",
      "నలుపు నలువెగని తెలుపురాదు",
      "కొమ్ముబొమ్ము డెచ్చు కొట్టిన బలకునా",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "ఎలుకతోలు ఎంత కడిగినా తెల్లగా మారదు.",
      "చెడు స్వభావం ఉన్నవాడు మారడం కష్టం."
    ],
    "moral": "స్వభావం మారడం కష్టం, కానీ ప్రయత్నం చేయాలి.",
    "audio": "vemana_006.mp3"
  },

  "vemana-007": {
    "title": "రాముడికడుపట్టీ రవికుల మీద్రై",
    "lines": [
      "రాముడికడుపట్టీ రవికుల మీద్రై",
      "కురుపతి జయియించి కులముజెపుచె",
      "ఇలను బుజ్జపావ మీలాగు కాదోకా",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "రాముడు తన కులాన్ని గౌరవించాడు.",
      "మనిషి తన కుటుంబం, విలువలను కాపాడాలి."
    ],
    "moral": "స్వకుల గౌరవం, ధర్మం కాపాడాలి.",
    "audio": "vemana_007.mp3"
  },

  "vemana-008": {
    "title": "అల్లుడెవడు వల్ల నాదంబరమును",
    "lines": [
      "అల్లుడెవడు వల్ల నాదంబరమును",
      "సజ్జనందుబలులజల్లగాను",
      "కంచుదోగనట్టుకనకంబు ద్రోగునా",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "అల్లుడు వల్ల అహంకారం పెరగకూడదు.",
      "సజ్జనులు వినయంతో ఉండాలి."
    ],
    "moral": "వినయం మనిషిని ఉన్నతుడిని చేస్తుంది.",
    "audio": "vemana_008.mp3"
  },

  "vemana-009": {
    "title": "మెడిపండుచూడ మెరిసై యుండు",
    "lines": [
      "మెడిపండుచూడ మెరిసై యుండు",
      "పాట్లవిచూడ బురుగులుండు",
      "పిరికవాని మదిని బింకమీలగురా",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "మెడిపండు బయట మెరిసినా లోపల బురుగులు ఉంటాయి.",
      "పిరికివాడు బయట ధైర్యంగా కనిపించినా లోపల భయపడుతాడు."
    ],
    "moral": "బాహ్య రూపం కాదు, అంతరంగం ముఖ్యం.",
    "audio": "vemana_009.mp3"
  },

  "vemana-010": {
    "title": "గంగిగుప్పాలు గండిడెనను చాలు",
    "lines": [
      "గంగిగుప్పాలు గండిడెనను చాలు",
      "కడివెడెనేమి ఖరముపాలు",
      "భక్తులుగు కూడు పడ్డెననుజాలు",
      "విశ్వదాభిరామ వినురవేము!"
    ],
    "meaning": [
      "గంగలో స్నానం చేసినా, భక్తి లేకపోతే ప్రయోజనం లేదు."
    ],
    "moral": "భక్తి, విశ్వాసం లేకుండా ఆచారాలు వ్యర్థం.",
    "audio": "vemana_010.mp3"
  }
}
